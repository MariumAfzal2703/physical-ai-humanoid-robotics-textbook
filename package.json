  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "jsdom": "^26.0.0",
    "typescript": "~5.6.2",
    "vitest": "^2.1.8"
  },
  "browserslist": {
    "production": [
      ">0.5%",
